release_standalone/

# 日志文件
*.log
logs/

# 编辑器和IDE文件
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
Thumbs.db
.DS_Store

# 备份文件
*.bak
backup/
history/

# 测试相关
.pytest_cache/

# 其他临时文件
