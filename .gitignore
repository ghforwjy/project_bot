# 临时文件和目录
__pycache__/
*.py[cod]
*$py.class

# 数据库文件
data/
*.db
*.sqlite

# 环境文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example

# 依赖目录
node_modules/
venv/
env/

# 构建输出
dist/
build/

# 发布目录（保留，用于分发）
